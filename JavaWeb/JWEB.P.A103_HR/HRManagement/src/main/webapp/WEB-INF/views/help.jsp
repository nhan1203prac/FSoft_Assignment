<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<div>
    <h6 class="text-success">Registration Guide</h6>
    <ul class="mb-0 pl-3" style="font-size:0.875rem;">
        <li><strong>First name / Last name</strong>: Required. Letters only, max 20 characters each.</li>
        <li><strong>Gender</strong>: Select Male or Female.</li>
        <li><strong>Telephone</strong>: Optional. Numbers only, max 11 digits.</li>
        <li><strong>Email</strong>: Optional. Must follow format <code>user@domain.com</code>, max 50 characters.</li>
        <li><strong>You are in</strong>: Required. Select your region.</li>
        <li><strong>Hobbies</strong>: Optional. Check all that apply.</li>
        <li><strong>Description</strong>: Optional. Free text, max 200 characters.</li>
    </ul>
    <p class="mt-2 mb-0 text-muted" style="font-size:0.8rem;">
        Fields marked with <span class="text-danger">*</span> are mandatory.
    </p>
</div>
